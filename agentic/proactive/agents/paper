\subsection{LSTM Delay Prediction Model}

\subsubsection{Architecture}
A two-layer stacked LSTM (hidden dimension 128, inter-layer
dropout 0.3) followed by a fully connected head:
\begin{align}
  \mathbf{h}_t,\mathbf{c}_t
    &= \mathrm{LSTM}(\mathbf{x}_t,\mathbf{h}_{t-1},
       \mathbf{c}_{t-1};\theta),
       \label{eq:lstm}\\
  \hat{y}
    &= \mathbf{W}_2\,\mathrm{ReLU}(\mathbf{W}_1
       \mathbf{h}_W+\mathbf{b}_1)+b_2,
       \label{eq:fc}
\end{align}
where $\mathbf{h}_W$ is the final-step hidden state. The head
maps $128\!\to\!64\!\to\!1$ with output dropout 0.2.

\subsubsection{Training procedure}
Adam optimizer ($\text{lr}=10^{-3}$), batch size 64, MSE loss:
\begin{equation}
  \mathcal{L}=\tfrac{1}{N}\sum_{j=1}^{N}(\hat{y}_j-y_j)^2.
  \label{eq:loss}
\end{equation}
Gradient norms clipped to 1.0. Early stopping with patience 6.
Patient-level split by \texttt{subject\_id}: 70\% train,
15\% validation, 15\% test.

\subsection{LangGraph Agentic Multi-Agent Architecture}

Agent coordination uses LangGraph, a directed graph-based
state-machine framework in which each pipeline is a computation
graph of autonomous agent functions connected by directed edges.
All agents operate on a shared typed \texttt{WorkflowState}:

\begin{verbatim}
class WorkflowState(TypedDict, total=False):
    stay_df:         pd.DataFrame
    trigger_time:    datetime
    sequence:        np.ndarray
    predicted_delay: float
    actual_delay:    float
    deviation:       float
    severity:        str
    alert_flag:      bool
    llm_explanation: str
\end{verbatim}

\subsubsection{Reactive pipeline (R1--R5)}
Evaluates deviation after laboratory completion
(Algorithm~\ref{alg:reactive}). R4 computes
$\delta=d_\text{actual}-\hat{d}$ from the observed delay.

\begin{algorithm}[!t]
\caption{Reactive agentic monitoring (post-event)}
\label{alg:reactive}
\begin{algorithmic}[1]
\REQUIRE Stay $s$, trigger index $i\!\geq\!W$, delay $d_i$
\STATE \textbf{R1}: Extract $(\tau_i,\phi_i,d_i)$ from $s$
\STATE \textbf{R2}: Build sequence
  $\mathbf{x}\leftarrow s[i-W\!:\!i]$
\STATE \textbf{R3}: $\hat{d}_i\leftarrow f_\theta(\mathbf{x})$
\STATE \textbf{R4}: $\delta_i\leftarrow d_i-\hat{d}_i$
\STATE \textbf{R5}: Classify $\delta_i$ per~\eqref{eq:sev}
\STATE \textbf{Alert}: Log result; invoke LLM if $\delta_i>0$
\end{algorithmic}
\end{algorithm}

\subsubsection{Proactive pipeline (P1--P5)}
Issues early warnings before laboratory completion
(Algorithm~\ref{alg:proactive}). P4 checks wall-clock time
against the predicted deadline without requiring an observed
delay.

\begin{algorithm}[!t]
\caption{Proactive agentic monitoring (pre-event)}
\label{alg:proactive}
\begin{algorithmic}[1]
\REQUIRE Stay $s$, current time $t_\text{now}$,
         labs $\mathcal{L}$, tolerance $\Delta=15$\,min
\STATE \textbf{P1}: Extract most recent trigger $\tau$
\STATE \textbf{P2}: Build sequence from last $W$ triggers
\STATE \textbf{P3}: $\hat{d}\leftarrow f_\theta(\mathbf{x})$;
  $t_\text{dl}\leftarrow\tau+\hat{d}$
\STATE \textbf{P4}: done $\leftarrow\exists\ell\in\mathcal{L}:
  \ell>\tau\wedge\ell\leq t_\text{now}$
\IF{$t_\text{now}>t_\text{dl}+\Delta$ \AND \NOT done}
  \STATE Raise proactive alert
\ENDIF
\STATE \textbf{P5}: If done, classify $\delta$
  per~\eqref{eq:sev}
\STATE \textbf{Alert}: Log; invoke LLM if alerted
\end{algorithmic}
\end{algorithm}

\subsubsection{Severity classification}
\begin{equation}
  \mathrm{severity}(\delta)=
  \begin{cases}
    \text{No delay}  & \delta\leq0,\\
    \text{Mild}      & 0<\delta\leq1,\\
    \text{Moderate}  & 1<\delta\leq3,\\
    \text{Severe}    & \delta>3.
  \end{cases}
  \label{eq:sev}
\end{equation}

\subsubsection{LLM explanation agent}
A locally deployed Llama~3.2 model (Ollama) receives the
trigger type, predicted delay, actual delay (if observed),
severity classification, and current vital sign vector, and
generates a structured clinical narrative covering: (i) the
clinical significance of the detected deviation; (ii) evidence
of workflow inefficiency; and (iii) potential patient risks
given the vital sign trajectory.

