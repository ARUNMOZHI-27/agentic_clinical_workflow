\section{Problem Formulation}
\label{sec:problem}
%%===========================================================

Let $\mathcal{S}=\{s_1,\ldots,s_N\}$ be a set of ICU stays.
For each stay $s_i$, let $\mathcal{T}^{(i)}=\{t_1,\ldots,
t_{M_i}\}$ be the time-ordered sequence of trigger events.

\begin{definition}[Trigger event]
$t_j=(\tau_j,\phi_j,\mathbf{v}_j)$ comprises a timestamp
$\tau_j$, a trigger type $\phi_j\in\{\texttt{HR\_HIGH},
\texttt{MAP\_LOW},\texttt{SPO2\_LOW},\texttt{RR\_HIGH}\}$,
and a vital sign vector $\mathbf{v}_j=[\mathrm{HR},
\mathrm{MAP},\mathrm{RR},\mathrm{SpO_2}]$.
\end{definition}

\begin{definition}[Diagnostic delay]
Let $\ell_j$ be the timestamp of the first relevant laboratory
event with $\ell_j>\tau_j$ in admission $s_i$. The diagnostic
delay is
\begin{equation}
  d_j = \tfrac{\ell_j - \tau_j}{3600} \quad (\text{hours}).
  \label{eq:delay}
\end{equation}
\end{definition}

\begin{definition}[Expected delay and workflow deviation]
Let $\mathbf{x}_j\in\mathbb{R}^{W\times F}$ be the feature
tensor of the $W$ triggers preceding $t_j$. A learned function
$f_\theta$ predicts expected delay $\hat{d}_j=f_\theta(
\mathbf{x}_j)$. The workflow deviation is
\begin{equation}
  \delta_j = d_j - \hat{d}_j.
  \label{eq:deviation}
\end{equation}
Positive $\delta_j$ indicates delay; negative indicates
completion ahead of expectation.
\end{definition}

The objective is to estimate $f_\theta$ from historical EHR
data and use $\delta_j$ for both post-event deviation
analysis~(reactive) and pre-event early warning~(proactive).

